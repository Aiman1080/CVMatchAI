# ─── Database (PostgreSQL via Supabase — free at supabase.com) ────────────────
# IMPORTANT: Use the POOLER URLs, not the direct connection (IPv4 compatible)
#
# Go to: Project Settings → Database → Connection string
# Switch to "URI" tab, then pick "Session pooling" mode
#
# For DATABASE_URL: copy the URI (port 5432, session mode)
# For DIRECT_URL:   same URI (port 5432, session mode)
# Replace [YOUR-PASSWORD] with your database password
# If password contains @, encode it as %40 in the URL
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase Storage (optional — stores CV/motivation binaries out of Postgres) ─
# Without these, CV files fall back to Postgres bytea (which fills the 500MB free
# tier fast). Create a private bucket named "cv-files", then:
#   SUPABASE_URL: Project Settings -> Data API (https://[ref].supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY: Project Settings -> API Keys -> Secret key (sb_secret_...). SERVER-ONLY.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Gemini AI (optional — app works in demo mode without this) ──────────────
# Get at: https://aistudio.google.com/apikey
# Leave empty for demo mode (AI features use built-in demo analysis)
GEMINI_API_KEY=""

# ─── SMTP (optional — for sending emails to candidates) ─────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
SMTP_SECURE="false"

# ─── Google Analytics (optional — measurement ID, e.g. G-XXXXXXXXXX) ───────
NEXT_PUBLIC_GA_ID=""

# ─── Contact / Support email (optional — defaults to contactcvmatchia@gmail.com)
CONTACT_EMAIL=""

# ─── Stripe (payment) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"
NEXT_PUBLIC_DEMO_MODE="true"
