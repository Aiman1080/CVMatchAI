# Database (SQLite for local dev, change to PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth - generate a strong secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Anthropic AI - get your key at https://console.anthropic.com
# Leave empty to use demo mode (no real AI, uses placeholder analysis)
ANTHROPIC_API_KEY=""

# App settings
APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"
