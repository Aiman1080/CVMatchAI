# ─── Database (PostgreSQL via Supabase — free at supabase.com) ────────────────
# 1. Go to https://supabase.com → New Project → choose a region (EU West)
# 2. Go to Project Settings → Database → Connection string (URI)
# 3. Copy the "Transaction" URI for DATABASE_URL (uses port 6543)
# 4. Copy the "Session" URI for DIRECT_URL (uses port 5432)
# 5. Replace [YOUR-PASSWORD] with your database password
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic AI (optional — app works in demo mode without this) ───────────
# Get at: https://console.anthropic.com → API Keys → Create Key
# Leave empty for demo mode (AI features use built-in demo analysis)
ANTHROPIC_API_KEY=""

# ─── SMTP (optional — for sending emails to candidates) ─────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
SMTP_SECURE="false"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"
