# ─── Database (PostgreSQL via Neon — free at neon.tech) ──────────────────────
# DATABASE_URL = Pooled connection string from Neon dashboard
# DIRECT_URL   = Direct connection string from Neon dashboard (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic AI ────────────────────────────────────────────────────────────
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"
