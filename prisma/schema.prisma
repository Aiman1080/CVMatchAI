generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String          @default("recruiter")
  company         String?
  subscription    String          @default("free")
  subscriptionEnd DateTime?
  suspended       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lastSeenAt      DateTime?
  accounts        Account[]
  sessions        Session[]
  vacancies       Vacancy[]
  candidates      Candidate[]
  emailInboxes    EmailInbox[]
  supportTickets  SupportTicket[]
  integrations    Integration[]
  notifications   Notification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vacancy {
  id             String      @id @default(cuid())
  title          String
  company        String
  department     String?
  location       String?
  type           String      @default("full-time")
  description    String
  requirements   String
  niceToHave     String?
  salary         String?
  status         String      @default("active")
  language       String      @default("nl")
  externalId     String?
  externalSource String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates     Candidate[]
}

model Integration {
  id          String    @id @default(cuid())
  platform    String
  apiKey      String
  companySlug String?
  status      String    @default("active")
  lastSyncAt  DateTime?
  syncCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, userId])
}

model Candidate {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  linkedIn        String?
  cvFileName      String?
  cvUrl           String?
  cvContent       String?
  motivationText  String?
  motivationUrl   String?
  language        String     @default("nl")
  matchScore      Float?
  summary         String?
  strengths       String?
  weaknesses      String?
  skills          String?
  experience      String?
  education       String?
  recommendation  String?
  status          String     @default("new")
  source          String     @default("upload")
  externalId      String?
  externalSource  String?
  gdprConsent     Boolean    @default(false)
  gdprConsentDate DateTime?
  analyzedAt      DateTime?
  notes           String?
  liked           Boolean    @default(false)
  priority        Boolean    @default(false)
  savedToPool     Boolean    @default(false)
  viewedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  vacancyId       String
  userId          String
  vacancy         Vacancy    @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailSource     EmailScan?
  activities      CandidateActivity[]

  // One candidate per email per vacancy — prevents duplicates from repeated demo scans or uploads
  @@unique([email, vacancyId])
  @@unique([externalId, externalSource, userId])
}

model CandidateActivity {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type        String    // status_change, note_added, email_sent, cv_analyzed, created
  description String
  metadata    String?   // JSON string for extra data
  createdAt   DateTime  @default(now())
}

model EmailInbox {
  id        String      @id @default(cuid())
  email     String
  provider  String
  host      String
  port      Int
  username  String
  password  String
  active    Boolean     @default(true)
  lastScan  DateTime?
  createdAt DateTime    @default(now())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans     EmailScan[]
}

model EmailScan {
  id          String     @id @default(cuid())
  subject     String
  sender      String
  receivedAt  DateTime
  processed   Boolean    @default(false)
  relevant    Boolean    @default(false)
  attachments String?
  createdAt   DateTime   @default(now())
  inboxId     String
  inbox       EmailInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  candidateId String?    @unique
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
}

model SupportTicket {
  id         String    @id @default(cuid())
  userId     String
  subject    String
  message    String
  status     String    @default("open") // open | in_progress | resolved | closed
  priority   String    @default("normal") // low | normal | high | urgent
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // cv_analyzed, ticket_reply, new_candidate, scan_complete
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Subscription {
  id            String   @id @default(cuid())
  plan          String
  price         Float
  features      String
  maxVacancies  Int
  maxCandidates Int
  aiAnalysis    Boolean  @default(true)
  emailScan     Boolean  @default(false)
  priority      Boolean  @default(false)
  createdAt     DateTime @default(now())
}
